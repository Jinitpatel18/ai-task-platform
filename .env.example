# Backend .env (copy to backend/.env and fill in values)
NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://admin:password@localhost:27017/ai_task_platform?authSource=admin
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
LOG_LEVEL=info

# Worker .env (copy to worker/.env and fill in values)
MONGODB_URI=mongodb://admin:password@localhost:27017/ai_task_platform?authSource=admin
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispassword
WORKER_ID=worker-0
LOG_LEVEL=INFO

# Frontend .env (copy to frontend/.env and fill in values)
REACT_APP_API_URL=http://localhost:5000/api
